DJANGO_ENV=production
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=troque-por-chave-forte-com-64-caracteres-ou-mais
JWT_SECRET_KEY=troque-por-outra-chave-forte-com-64-caracteres-ou-mais
JWT_EXP_HOURS=12
PAYMENT_PROVIDER=asaas
CORS_ALLOW_ALL_ORIGINS=false
DJANGO_ALLOWED_HOSTS=app-saude-p9n8.onrender.com,soluscrt.com.br,soluscrtsaude.com.br,empresa.soluscrt.com.br,governo.soluscrt.com.br,admin.soluscrt.com.br,app.soluscrt.com.br,.soluscrt.com.br,.soluscrtsaude.com.br
CSRF_TRUSTED_ORIGINS=https://app-saude-p9n8.onrender.com,https://soluscrt.com.br,https://soluscrtsaude.com.br,https://empresa.soluscrt.com.br,https://governo.soluscrt.com.br,https://admin.soluscrt.com.br,https://app.soluscrt.com.br
CORS_ALLOWED_ORIGINS=https://app-saude-p9n8.onrender.com,https://soluscrt.com.br,https://soluscrtsaude.com.br,https://empresa.soluscrt.com.br,https://governo.soluscrt.com.br,https://admin.soluscrt.com.br,https://app.soluscrt.com.br
PUBLIC_BASE_URL=https://app-saude-p9n8.onrender.com
DATABASE_URL=postgresql://usuario:senha@host:5432/database
# Obrigatorio em producao — Redis para rate limiting e cache entre workers
# Render: vincular no painel | Hostinger VPS: redis://127.0.0.1:6379/0
REDIS_URL=redis://usuario:senha@host:6379/0
# Disco persistente para arquivos de midia (DICOM, laudos, embeddings biometricos)
# Render: /var/data/media | Hostinger VPS: /home/soluscrt/media (ou caminho do disco)
MEDIA_ROOT_OVERRIDE=/var/data/media
# Chave Fernet para cifrar embeddings biometricos (LGPD Art. 11) — gerar com: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BIOMETRIA_EMBEDDING_KEY=gere-com-o-comando-acima-nunca-use-este-placeholder
ASAAS_API_KEY=$aact_prod_sua_chave_de_producao
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=defina_um_token_forte_para_validar_webhook
ASAAS_USER_AGENT=SolusCRT-Saude/1.0
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account"}
MAPBOX_ACCESS_TOKEN=configure-token-restrito
GOOGLE_MAPS_BROWSER_KEY=configure-chave-restrita
GOOGLE_MAPS_IOS_KEY=configure-chave-restrita
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=noreply@soluscrt.com.br
EMAIL_HOST_PASSWORD=senha-do-smtp-zoho
DEFAULT_FROM_EMAIL=SolusCRT <noreply@soluscrt.com.br>
SENTRY_DSN=https://SEU_DSN@oXXXXXX.ingest.sentry.io/XXXXXXXX
SOLUSCRT_BOOTSTRAP_EMPRESA_EMAIL=empresa@exemplo.com
SOLUSCRT_BOOTSTRAP_EMPRESA_PASSWORD=troque-por-senha-forte
SOLUSCRT_BOOTSTRAP_EMPRESA_NOME=Empresa Piloto
SOLUSCRT_BOOTSTRAP_GOVERNO_EMAIL=governo@exemplo.com
SOLUSCRT_BOOTSTRAP_GOVERNO_PASSWORD=troque-por-senha-forte
